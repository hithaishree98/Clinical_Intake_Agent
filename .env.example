# =============================================================================
# Hospital Assistant — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Required — the app will not start without these
# -----------------------------------------------------------------------------

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Secret used to sign JWT clinician tokens — use a long random string
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string

# Password for the /clinician/token endpoint
CLINICIAN_PASSWORD=change-me

# -----------------------------------------------------------------------------
# Database paths (defaults work for local dev; override for Docker volumes)
# -----------------------------------------------------------------------------

# Main application database (sessions, events, audit log)
# DATABASE_PATH=./hospital.db

# LangGraph checkpoint database (graph state persistence)
# CHECKPOINT_DB_PATH=./checkpoints.db

# -----------------------------------------------------------------------------
# LLM behaviour
# -----------------------------------------------------------------------------

# Gemini model name
# MODEL_NAME=gemini-2.0-flash

# Maximum tokens the model may generate per call
# MAX_OUTPUT_TOKENS=1024

# Temperature (0.0 = deterministic, 1.0 = creative)
# TEMPERATURE=0.2

# Circuit-breaker: consecutive failures before the breaker opens
# LLM_FAILURE_THRESHOLD=5

# Circuit-breaker: seconds before a half-open probe is attempted
# LLM_RECOVERY_TIMEOUT=60

# -----------------------------------------------------------------------------
# Webhook / outbound integrations (all optional)
# -----------------------------------------------------------------------------

# HMAC-SHA256 signing secret for outbound webhook payloads
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# WEBHOOK_SECRET=your-webhook-signing-secret

# Endpoint to receive completed intake bundles (FHIR R4 Bundle JSON)
# WEBHOOK_URL=https://your-ehr-system.example.com/intake/webhook

# Direct FHIR server base URL (alternative to webhook push)
# FHIR_SERVER_URL=https://your-fhir-server.example.com/fhir

# Slack webhook for escalation / crisis alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------

# Comma-separated origins allowed by CORS (use * only in dev)
# CORS_ORIGINS=http://localhost:3000,https://your-frontend.example.com

# Rate limit for the public /start and /message endpoints
# RATE_LIMIT=30/minute

# JWT token lifetime in minutes
# JWT_EXPIRY_MINUTES=60

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------

# Set to "true" to enable PHI audit logging (recommended in prod)
# AUDIT_LOGGING=true

# Set to "true" to emit structured JSON logs (recommended in prod; false = human-readable)
# JSON_LOGS=false

# Minimum extraction quality score (0.0-1.0) to auto-advance past subjective phase
# EXTRACTION_QUALITY_THRESHOLD=0.65
