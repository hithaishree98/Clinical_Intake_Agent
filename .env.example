# ── Required ──────────────────────────────────────────────────────────────────

# Gemini API key — get one free at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Secret used to sign clinician JWT tokens. Use any long random string.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_a_long_random_string

# Password for the clinician portal (POST /clinician/token)
CLINICIAN_PASSWORD=replace_with_a_strong_password


# ── Optional ──────────────────────────────────────────────────────────────────

# Gemini model name. Defaults to gemini-2.0-flash if not set.
# GEMINI_FLASH_MODEL=gemini-2.0-flash

# Set to true to skip the Gemini API validation check on startup.
# Useful for running tests without a real API key.
# DEBUG_MODE=false

# Outbound webhook — fired when an intake report is ready.
# The FHIR R4 Bundle is POSTed to this URL with an HMAC-SHA256 signature header.
# Leave blank to disable.
# COMPLETION_WEBHOOK_URL=https://your-ehr-system.com/intake-webhook
# COMPLETION_WEBHOOK_SECRET=replace_with_a_shared_secret

# Slack incoming webhook URL.
# Create one at: https://api.slack.com/apps → Incoming Webhooks → Activate → Add New Webhook
# Free. No Slack library needed — just an HTTP POST.
# Three events fire: emergency escalation, identity mismatch, intake complete.
# Leave blank to disable.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Slack incoming webhook URL for three events:
#   - Emergency escalation (fires immediately when a red flag is detected)
#   - Identity mismatch flagged for nurse review
#   - Intake completed (patient name, risk level, session ID)
# Get one free at: https://api.slack.com/messaging/webhooks
# Leave blank to disable all Slack notifications.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# SQLite database paths. Defaults work fine for local/Docker use.
# APP_DB_PATH=data/app.db
# CHECKPOINT_DB_PATH=data/checkpoints.db
